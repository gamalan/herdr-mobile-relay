WEB_PROJECT=herdr-mobile-relay
# WEB_BRANCH=main

# Voice input (transcription) — configured in ~/.config/herdr/agent-profiles.ini [transcribe] section

# Optional: only one relay should own deployment of a separately hosted
# Cloudflare Pages phone app. Prefer the guided configure-app-deploy action.
# HERDR_APP_DEPLOY_ORIGIN=https://app.example.com
# HERDR_CLOUDFLARE_PAGES_PROJECT=herdr-mobile-relay
# HERDR_CLOUDFLARE_PAGES_BRANCH=main
# HERDR_APP_DEPLOY_NPX=/absolute/path/to/npx
# HERDR_APP_DEPLOY_NODE_DIR=/absolute/path/to/node/bin
# Optional for non-interactive Wrangler authentication:
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
